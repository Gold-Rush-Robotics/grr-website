# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# ------------------------------------------------------------

# Postgres connection string used by Prisma and the application server.
# Replace the host/port/user/password/database with your container settings.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/49er_robotics_website"

# Password for the admin account.
# When set, enables a default admin account that can be used to sign in to the admin dashboard.
# This should only be used for local development or for first-time setup.
# ADMIN_PASSWORD="password"

# Secret used by Better Auth to sign and verify session data.
# In production, this should NOT match the example value, and should be generated randomly from
# a site like https://diceware.dmuth.org/ or https://www.uuidgenerator.net/.
BETTER_AUTH_SECRET="replace-this-in-production"

# Base URL better auth uses for redirects.
# This should match the base URL of the application (e.g. localhost for local development, or the production URL when deployed).
BETTER_AUTH_URL="http://localhost:3000"

# Configuration for S3-compatible object storage.
# These values should work with the default MinIO configuration when using docker-compose.yml.
S3_BUCKET="photos"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="admin"
S3_SECRET_ACCESS_KEY="password"
# MinIO requires this to be true; when using Cloudflare R2 this should be false
S3_FORCE_PATH_STYLE="true"
# Browser-facing base URL used for gallery images.
# When using MinIO this should be <minio_url>/<bucket_name>.
# With R2 this should be a subdomain of the main website (photos.49er-robotics.org).
S3_PUBLIC_URL="http://localhost:9000/photos"
